      "required": ["path", "packageMode"],
      "properties": {
        "path": {
          "type": "string"
        },
        "packageMode": {
          "type": "string",
          "enum": ["directory", "zip"]
        },
        "overwrite": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "options": {
      "type": "object",
      "properties": {
        "includeAssets": {
          "type": "boolean"
        },
        "includeManifest": {
          "type": "boolean"
        },
        "locale": {
          "type": "string"
        },
        "themeId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
