{
  "type": "object",
  "required": ["packageMode", "outputPath", "entryFile", "semanticHash", "assetCount"],
  "properties": {
    "packageMode": {
      "type": "string",
      "enum": ["directory", "zip"]
    },
    "outputPath": {
      "type": "string"
    },
    "entryFile": {
      "type": "string",
      "enum": ["index.html"]
    },
    "manifestFile": {
      "type": "string",
      "enum": ["conversion-manifest.json"]
    },
    "semanticHash": {
      "type": "string"
    },
    "assetCount": {
      "type": "integer"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
