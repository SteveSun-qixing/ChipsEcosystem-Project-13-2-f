{
  "type": "object",
  "required": ["source", "target", "output"],
  "properties": {
    "source": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["card", "html"]
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["html", "pdf", "image"]
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string"
        },
        "overwrite": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "options": {
      "type": "object",
      "properties": {
        "html": {
          "type": "object",
          "properties": {
            "packageMode": {
              "type": "string",
              "enum": ["zip", "directory"]
            },
            "includeAssets": {
              "type": "boolean"
            },
            "includeManifest": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "pdf": {
          "type": "object",
          "properties": {
            "pageSize": {
              "type": "string",
              "enum": ["A4", "A3", "Letter", "Legal"]
            },
            "landscape": {
              "type": "boolean"
            },
            "printBackground": {
              "type": "boolean"
            },
            "marginMm": {
              "type": "object",
              "properties": {
                "top": {
                  "type": "number"
                },
                "right": {
                  "type": "number"
                },
                "bottom": {
                  "type": "number"
                },
                "left": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "image": {
          "type": "object",
          "properties": {
            "format": {
              "type": "string",
              "enum": ["png", "jpeg", "webp"]
            },
            "width": {
              "type": "number"
            },
            "height": {
              "type": "number"
            },
            "scaleFactor": {
              "type": "number"
            },
            "background": {
              "type": "string",
              "enum": ["transparent", "white", "theme"]
            }
          },
          "additionalProperties": false
        },
        "locale": {
          "type": "string"
        },
        "themeId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
