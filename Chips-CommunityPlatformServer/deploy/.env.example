# 薯片社区平台服务器 - 开发环境配置
# 将此文件复制为 .env 并按实际修改

# ─── 服务器 ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
# BASE_URL 为外部访问地址（默认通过 deploy/nginx/nginx.conf 暴露在 80 端口）
BASE_URL=http://localhost

# ─── 数据库（PostgreSQL） ─────────────────────────────────────────
DATABASE_URL=postgresql://ccps_user:ccps_password@localhost:5432/ccps_db

# ─── 缓存（Redis） ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── 对象存储（MinIO S3 兼容） ────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio_access_key
S3_SECRET_KEY=minio_secret_key_change_me
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
# 可选：若留空，服务端默认使用 ${BASE_URL}/cdn 作为公开资源前缀
# S3_PUBLIC_URL=http://localhost/cdn

# ─── 安全：JWT ────────────────────────────────────────────────────
# 生产环境必须替换为 32 位以上的随机字符串
JWT_SECRET=change_me_to_a_32_char_random_string_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── 上传限制 ─────────────────────────────────────────────────────
MAX_CARD_SIZE_MB=500
MAX_BOX_SIZE_MB=100
MAX_AVATAR_SIZE_MB=5

# ─── 管理员初始账号（首次启动时自动创建，已存在则跳过） ──────────
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change_me_admin_password

# ─── 功能开关 ─────────────────────────────────────────────────────
ENABLE_SWAGGER=true

# ─── Host 插件安装配置（可选，逗号或换行分隔） ───────────────────
HOST_ACTIVE_THEME_ID=chips-official.default-theme
# HOST_CARD_PLUGIN_PATHS=Chips-BaseCardPlugin/richtext-BCP/manifest.yaml,Chips-BaseCardPlugin/image-BCP/manifest.yaml
# HOST_THEME_PLUGIN_PATHS=ThemePack/Chips-default/manifest.yaml
# HOST_MODULE_PLUGIN_PATHS=Chips-ModulePlugin/Chips-CardtoHTML-Plugin/dist/chips.module.chips.cardtohtml.plugin-0.1.0.cpk,Chips-ModulePlugin/Chips-FileConversion-Plugin/dist/chips.module.chips.fileconversion.plugin-0.1.0.cpk
