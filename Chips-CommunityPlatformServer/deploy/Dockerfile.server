FROM node:20-alpine AS builder

WORKDIR /app/Chips-CommunityPlatformServer

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

COPY Chips-CommunityPlatformServer/package.json ./
COPY Chips-CommunityPlatformServer/pnpm-lock.yaml ./
COPY Chips-CommunityPlatformServer/pnpm-workspace.yaml ./
COPY Chips-CommunityPlatformServer/tsconfig.base.json ./
COPY Chips-CommunityPlatformServer/packages/web/package.json ./packages/web/
COPY Chips-CommunityPlatformServer/packages/admin/package.json ./packages/admin/
COPY Chips-CommunityPlatformServer/packages/server/package.json ./packages/server/

COPY Chips-Host /app/Chips-Host
COPY Chips-BaseCardPlugin/image-BCP /app/Chips-BaseCardPlugin/image-BCP
COPY Chips-BaseCardPlugin/richtext-BCP /app/Chips-BaseCardPlugin/richtext-BCP
COPY Chips-ModulePlugin/Chips-HtmltoImage-Plugin /app/Chips-ModulePlugin/Chips-HtmltoImage-Plugin
COPY ThemePack/Chips-default /app/ThemePack/Chips-default

RUN pnpm install --frozen-lockfile

COPY Chips-CommunityPlatformServer/packages/server ./packages/server
COPY Chips-ModulePlugin/Chips-CardtoHTML-Plugin /app/Chips-ModulePlugin/Chips-CardtoHTML-Plugin
COPY Chips-ModulePlugin/Chips-FileConversion-Plugin /app/Chips-ModulePlugin/Chips-FileConversion-Plugin

RUN pnpm --filter @ccps/server build

FROM node:20-alpine AS production

WORKDIR /app/Chips-CommunityPlatformServer

ENV NODE_ENV=production

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

COPY Chips-CommunityPlatformServer/package.json ./
COPY Chips-CommunityPlatformServer/pnpm-lock.yaml ./
COPY Chips-CommunityPlatformServer/pnpm-workspace.yaml ./
COPY Chips-CommunityPlatformServer/tsconfig.base.json ./
COPY Chips-CommunityPlatformServer/packages/web/package.json ./packages/web/
COPY Chips-CommunityPlatformServer/packages/admin/package.json ./packages/admin/
COPY Chips-CommunityPlatformServer/packages/server/package.json ./packages/server/

COPY Chips-Host /app/Chips-Host
COPY Chips-BaseCardPlugin/image-BCP /app/Chips-BaseCardPlugin/image-BCP
COPY Chips-BaseCardPlugin/richtext-BCP /app/Chips-BaseCardPlugin/richtext-BCP
COPY Chips-ModulePlugin/Chips-HtmltoImage-Plugin /app/Chips-ModulePlugin/Chips-HtmltoImage-Plugin
COPY Chips-ModulePlugin/Chips-CardtoHTML-Plugin /app/Chips-ModulePlugin/Chips-CardtoHTML-Plugin
COPY Chips-ModulePlugin/Chips-FileConversion-Plugin /app/Chips-ModulePlugin/Chips-FileConversion-Plugin
COPY ThemePack/Chips-default /app/ThemePack/Chips-default

RUN pnpm install --frozen-lockfile --prod

COPY --from=builder /app/Chips-CommunityPlatformServer/packages/server/dist ./packages/server/dist
COPY Chips-CommunityPlatformServer/packages/server/.chips-server-host ./packages/server/.chips-server-host

WORKDIR /app/Chips-CommunityPlatformServer/packages/server

EXPOSE 3000

CMD ["node", "dist/server.js"]
