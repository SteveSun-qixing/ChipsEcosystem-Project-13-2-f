{
  "name": "chips-community-platform-server",
  "version": "1.0.0",
  "private": true,
  "description": "薯片社区平台服务器（Chips Community Platform Server）",
  "scripts": {
    "dev": "pnpm --filter @ccps/server dev",
    "build": "pnpm --filter @ccps/server build && pnpm --filter @ccps/web build && pnpm --filter @ccps/admin build",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "test": "pnpm --filter @ccps/server test",
    "db:generate": "pnpm --filter @ccps/server db:generate",
    "db:migrate": "pnpm --filter @ccps/server db:migrate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "extends": "../package.json"
  }
}
