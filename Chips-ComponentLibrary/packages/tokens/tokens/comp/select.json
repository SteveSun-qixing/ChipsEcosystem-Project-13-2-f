{
  "chips": {
    "comp": {
      "select": {
        "trigger": {
          "radius": "{chips.sys.radius.container}",
          "surface": {
            "idle": "{chips.sys.color.surface}",
            "focus": "{chips.sys.color.surface}"
          },
          "border": {
            "idle": "{chips.sys.color.on-surface}"
          }
        },
        "option": {
          "surface": {
            "selected": "{chips.sys.color.primary}"
          },
          "text": {
            "color": "{chips.sys.color.on-surface}"
          }
        }
      }
    }
  }
}
