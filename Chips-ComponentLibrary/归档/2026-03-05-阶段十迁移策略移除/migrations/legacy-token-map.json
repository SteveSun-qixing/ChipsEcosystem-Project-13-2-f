{
  "version": "1.0.0",
  "description": "旧 token 命名迁移到 chips v1 统一命名空间。",
  "exact": {
    "chips.component.card.cover.frame.border.default": "chips.comp.card-cover-frame.root.border.idle",
    "chips.component.card.cover.frame.background.default": "chips.comp.card-cover-frame.root.surface.idle",
    "chips.component.composite.card.window.background.default": "chips.comp.composite-card-window.root.surface.idle",
    "chips.component.composite.card.window.border.default": "chips.comp.composite-card-window.root.border.idle"
  },
  "prefix": {
    "chips.component.": "chips.comp.",
    "chips.system.": "chips.sys.",
    "chips.semantic.": "chips.sem.",
    "--chips-component-": "--chips-comp-",
    "--chips-system-": "--chips-sys-",
    "--chips-semantic-": "--chips-sem-"
  }
}
