{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ColorPickOutput",
  "type": "object",
  "required": ["backgroundColor", "accentColor"],
  "properties": {
    "backgroundColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "accentColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    }
  },
  "additionalProperties": false
}
