{
  "name": "chips-scaffold-app",
  "version": "0.1.0",
  "description": "薯片生态 应用插件（type: app）官方脚手架与工程模板",
  "private": true,
  "type": "module",
  "main": "dist/src/cli/app-scaffold-api.js",
  "exports": {
    ".": "./dist/src/cli/app-scaffold-api.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
