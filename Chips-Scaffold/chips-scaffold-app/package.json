    "test:templates": "node scripts/check-templates.mjs",
    "test:e2e": "npm run build && node scripts/run-generated-e2e.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
