{
  "chips": {
    "comp": {
      "button": {
        "root": {
          "radius": "{chips.sys.radius.container}",
          "surface": {
            "idle": "{chips.sys.color.primary}",
            "hover": "{chips.sys.color.primary}",
            "active": "{chips.sys.color.primary}",
            "disabled": "{chips.sys.color.surface}"
          }
        },
        "label": {
          "color": {
