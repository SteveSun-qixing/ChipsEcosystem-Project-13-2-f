{
  "chips": {
    "comp": {
      "loading-boundary": {
        "root": {
          "surface": "{chips.sys.color.surface}"
        },
        "fallback": {
          "surface": "{chips.sys.color.surface}"
        },
        "skeleton": {
          "surface": {
            "idle": "{chips.sys.color.surface}",
            "active": "{chips.sys.color.primary}"
          }
        },
        "status": {
          "color": {
            "info": "{chips.sys.color.primary}"
          }
        },
        "focus": {
          "outline": "{chips.sys.color.primary}"
        }
      }
    }
  }
}
