{
  "chips": {
    "comp": {
      "button": {
        "root": {
          "radius": "{chips.sys.radius.container}",
          "surface": {
            "idle": "{chips.sys.color.primary}",
            "hover": "{chips.sys.color.primary-hover}",
            "active": "{chips.sys.color.primary-active}",
            "disabled": "{chips.sys.color.surface-elevated}"
          }
        },
        "label": {
          "color": {
            "idle": "{chips.sys.color.primary-contrast}",
            "disabled": "{chips.sys.color.on-surface-soft}"
          }
        },
        "focus": {
          "outline": "{chips.sys.color.focus-ring}"
        }
      }
    }
  }
}
