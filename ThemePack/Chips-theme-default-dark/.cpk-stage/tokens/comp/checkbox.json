{
  "chips": {
    "comp": {
      "checkbox": {
        "control": {
          "radius": "{chips.ref.radius.sm}",
          "surface": {
            "unchecked": "{chips.sys.color.surface-raised}",
            "checked": "{chips.sys.color.primary}",
            "disabled": "{chips.sys.color.surface}"
          }
        },
        "indicator": {
          "color": {
            "checked": "{chips.sys.color.primary-contrast}"
          }
        },
        "label": {
          "color": "{chips.sys.color.on-surface}"
        }
      }
    }
  }
}
