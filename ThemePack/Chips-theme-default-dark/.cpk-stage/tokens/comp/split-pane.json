{
  "chips": {
    "comp": {
      "split-pane": {
        "root": {
          "surface": "{chips.sys.color.surface}"
        },
        "pane": {
          "surface": "{chips.sys.color.surface-raised}"
        },
        "handle": {
          "surface": {
            "idle": "{chips.sys.color.surface}",
            "active": "{chips.sys.color.surface-accent}"
          },
          "border": {
            "color": "{chips.sys.color.border-subtle}"
          }
        },
        "focus": {
          "outline": "{chips.sys.color.focus-ring}"
        }
      }
    }
  }
}
