{
  "chips": {
    "comp": {
      "input": {
        "root": {
          "radius": "{chips.sys.radius.container}",
          "surface": {
            "idle": "{chips.sys.color.surface-raised}",
            "focus": "{chips.sys.color.surface-elevated}"
          },
          "border": {
            "idle": "{chips.sys.color.border-subtle}",
            "error": "{chips.sys.color.error}"
          }
        },
        "value": {
          "color": "{chips.sys.color.on-surface}"
        },
        "placeholder": {
          "color": "{chips.sys.color.on-surface-soft}"
        }
      }
    }
  }
}
