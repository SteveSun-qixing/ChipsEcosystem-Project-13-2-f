{
  "name": "@chips/rich-text-card-plugin",
  "version": "1.0.0",
  "description": "富文本基础卡片插件 - 薯片生态",
  "author": "Chips Team",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "manifest.yaml",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue}\"",
    "type-check": "vue-tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "@vue/tsconfig": "^0.5.0",
    "eslint": "^8.56.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.2.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0",
    "vue-tsc": "^3.2.4"
  },
  "peerDependencies": {
    "@chips/foundation": "workspace:*",
    "@chips/sdk": "workspace:*"
  },
  "keywords": [
    "chips",
    "card",
    "rich-text",
    "plugin",
    "rtf"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chipscard/rich-text-card-plugin"
  },
  "bugs": {
    "url": "https://github.com/chipscard/rich-text-card-plugin/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
